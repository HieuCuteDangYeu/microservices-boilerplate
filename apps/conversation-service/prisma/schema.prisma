generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@prisma/conversation-client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("CONVERSATION_DATABASE_URL")
}

type MessageReadStatus {
  userId String
  at     DateTime
}

// Định nghĩa cấu trúc cho Signal Protocol Keys
type SignedPreKey {
  keyId     Int
  publicKey String
  signature String
}

type OneTimePreKey {
  keyId     Int
  publicKey String
}

// --- MODELS ---

model Conversation {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  creatorId      String   @map("creator_id")
  participantIds String[]
  
  // lastMessage chỉ lưu text hiển thị preview (ví dụ: "Tin nhắn mới", "[Hình ảnh]")
  // Vì nội dung thật đã bị mã hóa
  lastMessage    String?
  lastMessageAt  DateTime?
  
  isGroup        Boolean
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  messages       Message[]

  @@map("conversations")
  @@index([participantIds])
}

model Message {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  type           String   @default("text")

  // 2. SIGNAL TYPE: Dùng cho Mã hóa (Server chỉ chuyển tiếp)
  // 1: WhisperMessage (Tin bình thường)
  // 3: PreKeyWhisperMessage (Tin thiết lập phiên X3DH)
  signalType     Int      @map("signal_type")

  content           String   

  registrationId Int?     // ID thiết bị người gửi
  senderId       String
  
  conversationId String   @db.ObjectId
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  createdAt      DateTime @default(now())
  readBy         MessageReadStatus[]
  
  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}

// MODEL MỚI: Quản lý khóa Signal (Key Store)
model UserKeyBundle {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  
  userId         String   @unique // Mỗi user 1 bộ key (hoặc tách theo deviceId nếu cần)
  deviceId       Int
  registrationId Int
  identityKey    String

  // Composite Types (Nhúng trực tiếp vào document)
  signedPreKey   SignedPreKey
  oneTimePreKeys OneTimePreKey[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("user_key_bundles")
}